class Addition {
    int Add(int a, int b) {
        return a + b;
    }
}

class Sub extends Addition {
    int Add(int a, int b) { // same parameters
        return a + b + 10;
    }
}

public class Main {
    public static void main(String[] args) {
        Addition obj = new Sub();
        System.out.println(obj.Add(1, 2)); // 13
    }
}
